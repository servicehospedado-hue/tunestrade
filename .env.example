# ============================================
# POCKETOPTION TRADING ECOSYSTEM - CONFIGURAÇÕES
# ============================================

ENVIRONMENT=development
DEBUG=true

# ============================================
# API
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_db
DB_USER=postgres
DB_PASSWORD=
DB_ENABLED=true

# ============================================
# REDIS (cache distribuído — desativado por padrão)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_ENABLED=false

# ============================================
# CONEXÕES WSS
# ============================================
CONNECTION_MAX=1000
CONNECTION_HEARTBEAT_INTERVAL=20
CONNECTION_MAX_RECONNECTS=5
CONNECTION_RECONNECT_DELAY=5
CONNECTION_TIMEOUT=30
CONNECTION_PING_MAX_MISSED=3
CONNECTION_CLEANUP_INTERVAL=60
CONNECTION_STALE_TIMEOUT=300

# ============================================
# MONITORAMENTO DE ATIVOS
# ============================================
# Quantidade máxima de ativos a monitorar simultaneamente
MONITORING_ACTIVES_QUANTIDADE=10

# Payout mínimo para incluir o ativo (em %)
MONITORING_ACTIVES_PAYOUT_MINIMO=70

# ============================================
# NOTIFICAÇÕES PUSH
# ============================================
# Provedor: firebase | onesignal | expo
NOTIFICATION_PROVIDER=firebase

# Firebase — caminho para arquivo de credenciais JSON
# Obter em: https://console.firebase.google.com/ → Configurações → Cloud Messaging
FIREBASE_CREDENTIALS=

# OneSignal (gratuito até 10k dispositivos)
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# Expo Push
EXPO_ACCESS_TOKEN=
